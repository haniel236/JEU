# Serveur
NODE_ENV=development
PORT=4000

# Base de données PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zmj?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS / Frontend
CLIENT_URL="http://localhost:5173"

# Notifications push (Web Push) — générer les clés avec : npm run generate:vapid
# Laisser vide pour désactiver les notifications push.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@zmj.dev"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
